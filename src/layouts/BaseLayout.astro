---
import { ClientRouter } from 'astro:transitions';
import BaseHead, { type Props as HeadProps } from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';

export type Props = HeadProps & { showHeader?: boolean };

const { showHeader = true, ...head } = Astro.props;
---

<!doctype html>
<html lang="en" class="wrap-break-words antialiased">
    <head>
        <meta name="google-site-verification" content="LTzEn09g9hhLbegJVBuRH3zOnBLP7YFimyJbfgtJjQg" />
        <BaseHead {...head} />
        <script>
            if (localStorage.theme === 'dark') {
                document.documentElement.classList.add('dark');
            }
        </script>
        <ClientRouter />
        <script is:inline src="/theme-toggle.js"></script>
        <script defer src="https://umami.peguni.com/script.js" data-website-id="ef668f97-2426-4d9e-b735-d2294aa684b8"></script>
    </head>
    <body class="bg-main text-main">
        <div class="flex min-h-screen flex-col px-4 md:px-8">
            <Nav />
            {showHeader && <Header />}
            <main class="mx-auto w-full max-w-3xl grow">
                <slot />
            </main>
            <Footer />
        </div>
    </body>
</html>
